html,
body {
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
}

#map {
  width: 100%;
  height: 100%;
}

/* Leaflet control ต้องอยู่เหนือ tile แต่ไม่ควรทับ panel ฝั่งขวา */
.leaflet-control {
  z-index: 800;
}

.leaflet-draw-control {
  display: none;
}

/* Layer control ซ้ายบนวางห่างจาก zoom control เล็กน้อย */
.leaflet-left .leaflet-control-layers {
  margin-left: 10px;
  margin-top: 10px;
}

.leaflet-control-layers-expanded {
  max-width: min(280px, calc(100vw - 24px));
  max-height: 60vh;
  overflow-y: auto;
}

.location-panel,
.result-panel {
  /* Panel หลักลอยทับแผนที่ แต่ยังต่ำกว่า popup ที่ต้องเห็นชัด */
  position: fixed;
  right: 16px;
  z-index: 1000;
  width: min(390px, calc(100vw - 32px));
  overflow: hidden;
  background: #ffffff;
  border: 1px solid #d6d9de;
  border-radius: 8px;
  box-shadow: 0 12px 32px rgba(15, 23, 42, 0.18);
}

.location-panel {
  top: 16px;
  display: flex;
  flex-direction: column;
}

.result-panel {
  top: 294px;
  bottom: 16px;
  display: none;
}

.result-panel.is-open {
  display: flex;
  flex-direction: column;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 14px 16px;
  border-bottom: 1px solid #e5e7eb;
}

.panel-header h2 {
  margin: 0;
  color: #111827;
  font-size: 18px;
  font-weight: 700;
}

.panel-close,
.panel-button {
  cursor: pointer;
  border: 1px solid #0f766e;
  border-radius: 6px;
  background: #0f766e;
  color: #ffffff;
  font: inherit;
}

.panel-close {
  min-height: 38px;
  padding: 7px 12px;
}

.panel-button {
  min-height: 44px;
  padding: 9px 12px;
  font-weight: 700;
}

.panel-button.secondary {
  background: #ffffff;
  color: #0f766e;
}

.panel-button:disabled {
  cursor: not-allowed;
  border-color: #cbd5e1;
  background: #e5e7eb;
  color: #64748b;
}

.panel-content {
  overflow: auto;
  padding: 14px 16px 20px;
}

.location-status,
.location-instruction {
  margin: 0 0 10px;
  color: #374151;
  font-size: 14px;
  line-height: 1.45;
}

.location-instruction {
  color: #6b7280;
}

.location-list {
  display: grid;
  gap: 8px;
  margin: 0 0 14px;
}

.location-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.result-section {
  padding: 12px 0;
  border-bottom: 1px solid #eef0f3;
}

.result-section:last-child {
  border-bottom: 0;
}

.result-section h3,
.map-popup h3 {
  margin: 0 0 10px;
  color: #111827;
  font-size: 16px;
}

.result-list,
.popup-list {
  display: grid;
  gap: 8px;
  margin: 0;
}

.result-field {
  display: grid;
  grid-template-columns: minmax(110px, 38%) 1fr;
  gap: 10px;
}

.result-label,
.result-value {
  margin: 0;
  color: #374151;
  font-size: 14px;
  line-height: 1.45;
}

.result-label {
  color: #6b7280;
}

.result-message,
.popup-message {
  margin: 0;
  color: #374151;
  font-size: 14px;
  line-height: 1.5;
  white-space: pre-line;
}

.parcel-suitability-section {
  display: grid;
  gap: 16px;
}

.parcel-crop-result {
  display: grid;
  gap: 10px;
}

.parcel-crop-result + .parcel-crop-result {
  padding-top: 14px;
  border-top: 1px solid #eef0f3;
}

.parcel-crop-result__title {
  margin: 0;
  color: #111827;
  font-size: 16px;
}

.parcel-crop-result__primary,
.parcel-crop-result__distribution {
  display: grid;
  gap: 8px;
}

.parcel-crop-result__summary-label,
.parcel-crop-result__distribution-title {
  margin: 0;
  color: #6b7280;
  font-size: 13px;
  line-height: 1.45;
}

.parcel-crop-result__primary-line {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
}

.parcel-crop-result__primary-label,
.parcel-crop-result__primary-percent,
.parcel-crop-result__primary-metrics,
.parcel-crop-result__distribution-class,
.parcel-crop-result__distribution-metrics,
.parcel-suitability-source {
  min-width: 0;
  color: #374151;
  font-size: 14px;
  line-height: 1.5;
}

.parcel-crop-result__primary-label {
  font-weight: 700;
  color: #111827;
}

.parcel-crop-result__primary-percent {
  color: #4b5563;
  font-weight: 700;
}

.parcel-crop-result__distribution-list {
  display: grid;
  gap: 8px;
}

.parcel-crop-result__distribution-item {
  display: grid;
  gap: 2px;
}

.parcel-crop-result__distribution-class {
  font-weight: 600;
  color: #111827;
}

.parcel-suitability-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 38px;
  padding: 4px 9px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 700;
  line-height: 1.2;
}

.parcel-suitability-badge.status-s1 {
  background: #15803d;
  color: #ffffff;
}

.parcel-suitability-badge.status-s2 {
  background: #ca8a04;
  color: #111827;
}

.parcel-suitability-badge.status-s3 {
  background: #ea580c;
  color: #ffffff;
}

.parcel-suitability-badge.status-n {
  background: #dc2626;
  color: #ffffff;
}

.parcel-suitability-badge.status-no-coverage {
  background: #94a3b8;
  color: #ffffff;
}

.parcel-suitability-source {
  padding-top: 4px;
  color: #6b7280;
  font-size: 13px;
}

.suitability-summary-card {
  /* Card สรุปด้านบนบอกผลจากชั้นข้อมูล Potential ก่อนเปิดดูรายละเอียด */
  display: grid;
  gap: 14px;
  margin: 0 0 16px;
  overflow: hidden;
  border: 1px solid #d6d9de;
  border-radius: 8px;
  background: #ffffff;
}

.suitability-card-header {
  display: grid;
  gap: 4px;
  padding: 14px 16px;
  border-bottom: 1px solid #e5e7eb;
}

.suitability-grade {
  width: fit-content;
  max-width: 100%;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 700;
  line-height: 1.35;
}

.suitability-label {
  color: #111827;
  font-size: 15px;
  font-weight: 700;
  line-height: 1.4;
}

.status-not-evaluated {
  background: #f8fafc;
}

.status-not-evaluated .suitability-grade {
  background: #e5e7eb;
  color: #374151;
}

.status-s1 {
  background: #f0fdf4;
}

.status-s1 .suitability-grade {
  background: #15803d;
  color: #ffffff;
}

.status-s2 {
  background: #fefce8;
}

.status-s2 .suitability-grade {
  background: #ca8a04;
  color: #111827;
}

.status-s3 {
  background: #fff7ed;
}

.status-s3 .suitability-grade {
  background: #ea580c;
  color: #ffffff;
}

.status-n {
  background: #fef2f2;
}

.status-n .suitability-grade {
  background: #dc2626;
  color: #ffffff;
}

.status-no-coverage {
  background: #f8fafc;
}

.status-no-coverage .suitability-grade {
  background: #94a3b8;
  color: #ffffff;
}

.suitability-card-body {
  display: grid;
  gap: 14px;
  padding: 0 16px;
}

.summary-card-group {
  display: grid;
  gap: 8px;
}

.summary-card-group h4 {
  margin: 0;
  color: #111827;
  font-size: 14px;
  font-weight: 700;
}

.summary-card-list {
  display: grid;
  gap: 7px;
  margin: 0;
}

.summary-card-row {
  display: grid;
  grid-template-columns: minmax(112px, 40%) 1fr;
  gap: 10px;
}

.summary-card-label,
.summary-card-value {
  min-width: 0;
  margin: 0;
  color: #374151;
  font-size: 13px;
  line-height: 1.45;
  overflow-wrap: anywhere;
}

.summary-card-label {
  color: #6b7280;
}

.summary-card-message {
  margin: 0;
  color: #374151;
  font-size: 13px;
  line-height: 1.5;
}

.suitability-card-footer {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 8px 12px;
  padding: 12px 16px 14px;
  border-top: 1px solid #e5e7eb;
  background: #f9fafb;
}

.suitability-status-pill {
  max-width: 100%;
  padding: 4px 9px;
  border-radius: 999px;
  background: #e5e7eb;
  color: #374151;
  font-size: 12px;
  font-weight: 700;
  line-height: 1.4;
}

.summary-coordinate {
  color: #4b5563;
  font-size: 12px;
  line-height: 1.4;
}

.map-popup {
  min-width: 220px;
}

.map-popup .result-field {
  grid-template-columns: 90px 1fr;
}

.parcel-draw-control {
  display: grid;
  gap: 8px;
  padding: 10px;
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid #d6d9de;
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(15, 23, 42, 0.14);
}

.parcel-draw-control .panel-button {
  min-height: 38px;
}

.parcel-section {
  margin-top: 10px;
  padding-top: 12px;
  border-top: 1px solid #e5e7eb;
}

.parcel-section h3 {
  margin: 0 0 10px;
  color: #111827;
  font-size: 15px;
}

.parcel-list {
  display: grid;
  gap: 10px;
}

.parcel-empty,
.parcel-note {
  margin: 0;
  color: #6b7280;
  font-size: 13px;
  line-height: 1.45;
}

.parcel-item {
  display: grid;
  gap: 8px;
  padding: 10px 12px;
  border: 1px solid #d6d9de;
  border-radius: 8px;
  background: #f8fafc;
}

.parcel-item.is-selected {
  border-color: #0f766e;
  box-shadow: inset 0 0 0 1px #0f766e;
  background: #f0fdfa;
}

.parcel-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.parcel-item-name {
  margin: 0;
  color: #111827;
  font-size: 14px;
  font-weight: 700;
}

.parcel-item-status {
  margin: 0;
  color: #475569;
  font-size: 12px;
}

.parcel-item-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.parcel-action {
  cursor: pointer;
  min-height: 34px;
  padding: 6px 10px;
  border: 1px solid #cbd5e1;
  border-radius: 6px;
  background: #ffffff;
  color: #0f172a;
  font: inherit;
  font-size: 13px;
}

.parcel-modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 1400;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
  background: rgba(15, 23, 42, 0.42);
}

.parcel-modal {
  width: min(420px, calc(100vw - 32px));
  padding: 18px;
  background: #ffffff;
  border-radius: 10px;
  box-shadow: 0 18px 40px rgba(15, 23, 42, 0.28);
}

.parcel-modal h3 {
  margin: 0 0 12px;
  color: #111827;
  font-size: 18px;
}

.parcel-modal label {
  display: grid;
  gap: 6px;
  color: #374151;
  font-size: 14px;
}

.parcel-modal input {
  min-height: 42px;
  padding: 8px 10px;
  border: 1px solid #cbd5e1;
  border-radius: 6px;
  font: inherit;
  font-size: 14px;
}

.parcel-modal-error {
  min-height: 18px;
  margin: 8px 0 0;
  color: #b91c1c;
  font-size: 13px;
}

.parcel-modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 16px;
}

.parcel-popup-title {
  margin: 0 0 8px;
  color: #111827;
  font-size: 15px;
  font-weight: 700;
}

.parcel-popup-details-button {
  cursor: pointer;
  min-height: 38px;
  padding: 8px 12px;
  border: 1px solid #0f766e;
  border-radius: 6px;
  background: #0f766e;
  color: #ffffff;
  font: inherit;
  font-size: 13px;
  font-weight: 700;
}

.parcel-popup-details-button:hover {
  border-color: #115e59;
  background: #115e59;
}

.parcel-popup-details-button:focus-visible {
  outline: 3px solid #99f6e4;
  outline-offset: 2px;
}

@media (max-width: 700px) {
  /* มือถือ: ย้าย panel ลงล่างเป็น bottom sheet เพื่อไม่บังแผนที่ทั้งหน้า */
  .location-panel,
  .result-panel {
    top: auto;
    right: 0;
    bottom: 0;
    left: 0;
    width: auto;
    max-height: 72vh;
    border-right: 0;
    border-bottom: 0;
    border-left: 0;
    border-radius: 8px 8px 0 0;
  }

  .location-panel {
    bottom: 0;
    z-index: 1001;
    max-height: 62vh;
  }

  .result-panel {
    max-height: 72vh;
  }

  .result-panel.is-open {
    z-index: 1002;
  }

  .panel-close {
    min-width: 56px;
    min-height: 44px;
  }

  .location-actions {
    grid-template-columns: 1fr;
  }

  .parcel-item-header,
  .parcel-modal-actions {
    align-items: stretch;
    flex-direction: column;
  }

  .parcel-item-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .summary-card-row {
    grid-template-columns: 1fr;
    gap: 2px;
  }

  .suitability-card-footer {
    align-items: flex-start;
    flex-direction: column;
  }
}

/* Desktop/mobile sidebar override */
.app-sidebar {
  position: fixed;
  top: 16px;
  right: 16px;
  bottom: 16px;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  gap: 12px;
  width: min(390px, calc(100vw - 32px));
  pointer-events: none;
}

.app-sidebar .location-panel,
.app-sidebar .result-panel {
  position: static;
  right: auto;
  left: auto;
  top: auto;
  bottom: auto;
  width: 100%;
  pointer-events: auto;
}

.app-sidebar .location-panel {
  flex: 0 0 auto;
}

.app-sidebar .result-panel {
  flex: 1 1 auto;
  min-height: 0;
}

.app-sidebar .panel-content {
  min-height: 0;
}

@media (max-width: 700px) {
  .app-sidebar {
    top: auto;
    right: 0;
    bottom: 0;
    left: 0;
    width: auto;
    gap: 0;
  }

  .app-sidebar .location-panel,
  .app-sidebar .result-panel {
    width: auto;
  }
}

.crop-suitability-summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  padding: 16px;
  border-bottom: 1px solid #e5e7eb;
}

.crop-suitability-summary {
  display: grid;
  gap: 8px;
  padding: 14px 16px;
  border: 1px solid #d6d9de;
  border-radius: 8px;
}

.crop-suitability-summary-title {
  margin: 0;
  color: #111827;
  font-size: 14px;
  font-weight: 700;
  line-height: 1.45;
}

.crop-suitability-summary-grade {
  width: fit-content;
  max-width: 100%;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 700;
  line-height: 1.35;
}

.crop-suitability-summary-label {
  margin: 0;
  color: #374151;
  font-size: 14px;
  line-height: 1.5;
}

.crop-suitability-summary.status-not-evaluated {
  background: #f8fafc;
}

.crop-suitability-summary.status-not-evaluated .crop-suitability-summary-grade {
  background: #e5e7eb;
  color: #374151;
}

.crop-suitability-summary.status-s1 {
  background: #f0fdf4;
}

.crop-suitability-summary.status-s1 .crop-suitability-summary-grade {
  background: #15803d;
  color: #ffffff;
}

.crop-suitability-summary.status-s2 {
  background: #fefce8;
}

.crop-suitability-summary.status-s2 .crop-suitability-summary-grade {
  background: #ca8a04;
  color: #111827;
}

.crop-suitability-summary.status-s3 {
  background: #fff7ed;
}

.crop-suitability-summary.status-s3 .crop-suitability-summary-grade {
  background: #ea580c;
  color: #ffffff;
}

.crop-suitability-summary.status-n {
  background: #fef2f2;
}

.crop-suitability-summary.status-n .crop-suitability-summary-grade {
  background: #dc2626;
  color: #ffffff;
}

.crop-suitability-summary.status-no-coverage {
  background: #f8fafc;
}

.crop-suitability-summary.status-no-coverage .crop-suitability-summary-grade {
  background: #94a3b8;
  color: #ffffff;
}

.parcel-draw-button.is-active {
  border-color: #9f1239;
  background: #be123c;
  color: #ffffff;
}

.parcel-draw-button.is-active:hover,
.parcel-draw-button.is-active:active {
  border-color: #881337;
  background: #9f1239;
}

.parcel-draw-button:focus-visible,
.parcel-popup-details-button:focus-visible,
.panel-button:focus-visible,
.panel-close:focus-visible {
  outline: 3px solid #99f6e4;
  outline-offset: 2px;
}

@media (min-width: 1100px) {
  .app-sidebar {
    top: 20px;
    right: 20px;
    bottom: 20px;
    display: grid;
    grid-template-columns: minmax(430px, 500px) minmax(320px, 380px);
    gap: 14px;
    align-items: start;
    width: auto;
    max-width: calc(100vw - 40px);
  }

  .app-sidebar:not(.has-result-panel) {
    grid-template-columns: minmax(320px, 380px);
  }

  .app-sidebar .result-panel {
    grid-column: 1;
    max-height: calc(100vh - 40px);
    min-height: 0;
    overflow: hidden;
  }

  .app-sidebar .location-panel {
    grid-column: 2;
    max-height: calc(100vh - 40px);
  }

  .app-sidebar:not(.has-result-panel) .location-panel {
    grid-column: 1;
  }

  .app-sidebar .panel-content {
    overflow-y: auto;
  }
}

@media (max-width: 1099px) {
  .app-sidebar {
    display: flex;
    flex-direction: column;
    width: min(390px, calc(100vw - 32px));
    gap: 12px;
  }
}

@media (max-width: 820px) {
  .crop-suitability-summary-grid {
    grid-template-columns: 1fr;
  }
}
